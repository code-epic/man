\newenvironment{cajaFormula}[1]
{\begin{tcolorbox}[
    colback=sentinelLight,
    colframe=sentinelCyan,
    title={\ faIcon{calculator}\ #1},
    title style={sentinelDark, font=\bfseries},
    boxrule=1.5pt,
    rounded corners,
    after skip=1em
]}
{\end{tcolorbox}}

